<Window x:Class="Em68030.Views.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Em68030.Properties"
        Title="{x:Static p:Strings.Window_Console}" Height="510" Width="700"
        Background="#FF0C0C0C"
        WindowStartupLocation="CenterOwner"
        InputMethod.IsInputMethodEnabled="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="OutputBox" Grid.Row="0"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas" FontSize="14"
                 Background="#FF0C0C0C" Foreground="#FF00FF00"
                 CaretBrush="#FF0C0C0C" BorderThickness="0"
                 Padding="4"
                 AcceptsReturn="True"
                 IsUndoEnabled="False"
                 InputMethod.IsInputMethodEnabled="False" />

        <!-- Focus indicator bar (WinUI3-style accent bar at the bottom) -->
        <Border x:Name="FocusIndicator" Grid.Row="1" Height="2"
                Background="{x:Static SystemParameters.WindowGlassBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=OutputBox}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </Grid>
</Window>
