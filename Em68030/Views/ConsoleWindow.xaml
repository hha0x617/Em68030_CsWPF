<Window x:Class="Em68030.Views.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Em68030.Properties"
        Title="{x:Static p:Strings.Window_Console}" Height="510" Width="700"
        Background="#FF0C0C0C"
        WindowStartupLocation="CenterOwner"
        InputMethod.IsInputMethodEnabled="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="OutputBox" Grid.Row="0"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Visible"
                 HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas" FontSize="14"
                 Background="#FF0C0C0C" Foreground="#FF00FF00"
                 CaretBrush="#FF0C0C0C" BorderThickness="0"
                 Padding="4"
                 AcceptsReturn="True"
                 IsUndoEnabled="False"
                 InputMethod.IsInputMethodEnabled="False">
            <TextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="ApplicationCommands.Copy" />
                    <MenuItem Command="ApplicationCommands.Paste" />
                    <Separator />
                    <MenuItem Command="ApplicationCommands.SelectAll" />
                </ContextMenu>
            </TextBox.ContextMenu>
        </TextBox>

        <!-- Search bar (hidden by default, shown at bottom) -->
        <Grid x:Name="SearchBar" Grid.Row="1" Background="#FF2D2D30"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" Margin="4"
                     FontFamily="Consolas" FontSize="13"
                     Background="#FF1E1E1E" Foreground="#FFD4D4D4"
                     BorderBrush="#FF3F3F46" Padding="4,2" />
            <ToggleButton x:Name="RegexToggle" Grid.Column="1" Content=".*"
                    FontFamily="Consolas" FontSize="10"
                    Background="Transparent" BorderThickness="0"
                    Padding="6,4" Margin="2,0" ToolTip="Regular Expression" />
            <TextBlock x:Name="SearchStatus" Grid.Column="2"
                       Foreground="#FF808080" FontSize="12"
                       VerticalAlignment="Center" Margin="8,0" />
            <Button x:Name="SearchPrevBtn" Grid.Column="3" Content="▲"
                    FontSize="10" Background="Transparent" BorderThickness="0"
                    Padding="6,4" Margin="2,0" ToolTip="Previous (Shift+F3)"
                    Click="SearchPrev_Click" />
            <Button x:Name="SearchNextBtn" Grid.Column="4" Content="▼"
                    FontSize="10" Background="Transparent" BorderThickness="0"
                    Padding="6,4" Margin="2,0" ToolTip="Next (F3)"
                    Click="SearchNext_Click" />
            <Button x:Name="SearchCloseBtn" Grid.Column="5" Content="✕"
                    FontSize="10" Background="Transparent" BorderThickness="0"
                    Padding="6,4" Margin="2,0" ToolTip="Close (Esc)"
                    Click="SearchClose_Click" />
        </Grid>

        <!-- Focus indicator bar (accent bar at the bottom) -->
        <Border x:Name="FocusIndicator" Grid.Row="2" Height="2"
                Background="#FF4CC2FF" Visibility="Collapsed" />
    </Grid>
</Window>
