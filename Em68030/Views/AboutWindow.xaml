<Window x:Class="Em68030.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Em68030.Properties"
        Title="{x:Static p:Strings.About_Title}" Height="300" Width="350"
        Background="{DynamicResource ThemeWindowBg}" Foreground="{DynamicResource ThemeForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{x:Static p:Strings.Dialog_OK}" Width="80" IsCancel="True" Margin="4"
                    Background="{DynamicResource ThemeAccentBanner}" Foreground="{DynamicResource ThemeHighlightFg}" Padding="4" />
        </StackPanel>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Image Source="/Assets/em68030_icon.png" Width="48" Height="48"
                       Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Em68030" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeAccent}" />
                    <TextBlock Text="{x:Static p:Strings.About_Subtitle}" FontSize="13"
                               Foreground="{DynamicResource ThemeForeground}" />
                </StackPanel>
            </StackPanel>
            <TextBlock x:Name="VersionText" FontSize="13"
                       Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,2" />
            <TextBlock x:Name="BuildHashText" FontSize="13"
                       Foreground="{DynamicResource ThemeBuildHashFg}" Margin="0,0,0,12" />
            <TextBlock Text="{x:Static p:Strings.About_Copyright}" FontSize="13"
                       Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,2" />
            <TextBlock Text="{x:Static p:Strings.About_License}" FontSize="13"
                       Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,2" />
            <TextBlock FontSize="13" Foreground="{DynamicResource ThemeAccent}">
                <Hyperlink NavigateUri="https://github.com/hha0x617/Em68030_CsWPF"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{DynamicResource ThemeAccent}">
                    https://github.com/hha0x617/Em68030_CsWPF
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </DockPanel>
</Window>
