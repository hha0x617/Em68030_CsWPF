<Window x:Class="Em68030.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="300" Width="350"
        Background="#FF1E1E1E" Foreground="#FFD4D4D4"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="80" IsCancel="True" Margin="4"
                    Background="#FF0E639C" Foreground="White" Padding="4" />
        </StackPanel>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Image Source="/Assets/em68030_icon.png" Width="48" Height="48"
                       Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Em68030" FontSize="20" FontWeight="Bold"
                               Foreground="#FF569CD6" />
                    <TextBlock Text="MC68030 Emulator (C#/WPF)" FontSize="13"
                               Foreground="#FFD4D4D4" />
                </StackPanel>
            </StackPanel>
            <TextBlock Text="Version 0.1.0" FontSize="13"
                       Foreground="#FFD4D4D4" Margin="0,0,0,2" />
            <TextBlock x:Name="BuildHashText" FontSize="13"
                       Foreground="#FF888888" Margin="0,0,0,12" />
            <TextBlock Text="&#x00A9; 2026 hha0x617" FontSize="13"
                       Foreground="#FFD4D4D4" Margin="0,0,0,2" />
            <TextBlock Text="Licensed under Apache-2.0" FontSize="13"
                       Foreground="#FFD4D4D4" Margin="0,0,0,2" />
            <TextBlock FontSize="13" Foreground="#FF569CD6">
                <Hyperlink NavigateUri="https://github.com/hha0x617/Em68030_CsWPF"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#FF569CD6">
                    https://github.com/hha0x617/Em68030_CsWPF
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </DockPanel>
</Window>
