<Window x:Class="Em68030.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Em68030.Properties"
        Title="{x:Static p:Strings.Window_Input}" Height="160" Width="350"
        Background="{DynamicResource ThemeWindowBg}" Foreground="{DynamicResource ThemeForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Text="{x:Static p:Strings.FileDialog_EnterLoadAddress}" Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,8" />
        <TextBox x:Name="InputTextBox" FontFamily="Consolas" FontSize="14"
                 Background="{DynamicResource ThemeInputBg}" Foreground="{DynamicResource ThemeForeground}"
                 CaretBrush="{DynamicResource ThemeHighlightFg}" BorderBrush="{DynamicResource ThemeBorder}"
                 Padding="4" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static p:Strings.Dialog_OK}" Width="70" Click="OK_Click" IsDefault="True"
                    Background="{DynamicResource ThemeAccentBanner}" Foreground="{DynamicResource ThemeHighlightFg}" Padding="4" Margin="4,0" />
            <Button Content="{x:Static p:Strings.Dialog_Cancel}" Width="70" IsCancel="True"
                    Background="{DynamicResource ThemeControlBg}" Foreground="{DynamicResource ThemeForeground}" Padding="4" />
        </StackPanel>
    </StackPanel>
</Window>
