<Window x:Class="Em68030.Views.BreakpointsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Em68030.Properties"
        Title="{x:Static p:Strings.Window_Breakpoints}" Height="400" Width="360"
        Background="{DynamicResource ThemeWindowBg}" Foreground="{DynamicResource ThemeForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Breakpoint list -->
        <ListView x:Name="BreakpointList" Grid.Row="0"
                  Background="{DynamicResource ThemeWindowBg}" BorderThickness="0"
                  Foreground="{DynamicResource ThemeForeground}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="BreakpointList_MouseDoubleClick">
            <ListView.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{Binding Color, Source={StaticResource ThemeListSelection}}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{Binding Color, Source={StaticResource ThemeListSelection}}" />
            </ListView.Resources>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Bottom toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="{DynamicResource ThemePanelBg}" Height="36">
            <Button x:Name="AddWatchpointButton" Content="{x:Static p:Strings.Breakpoints_AddWatchpoint}" Click="AddWatchpoint_Click"
                    Background="{DynamicResource ThemeControlBg}" Foreground="{DynamicResource ThemeForeground}"
                    BorderBrush="{DynamicResource ThemeButtonBorder}" Padding="8,3" Margin="4"
                    FontSize="12" />
            <Button x:Name="ClearAllButton" Content="{x:Static p:Strings.Breakpoints_ClearAll}" Click="ClearAll_Click"
                    Background="{DynamicResource ThemeControlBg}" Foreground="{DynamicResource ThemeForeground}"
                    BorderBrush="{DynamicResource ThemeButtonBorder}" Padding="8,3" Margin="4"
                    FontSize="12" />
        </StackPanel>
    </Grid>
</Window>
