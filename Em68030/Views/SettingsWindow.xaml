<Window x:Class="Em68030.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:Em68030.Properties"
        Title="{x:Static p:Strings.Window_Settings}" Height="600" Width="540"
        Background="#FF1E1E1E" Foreground="#FFD4D4D4"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SettingTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="BorderBrush" Value="#FF3F3F46" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF569CD6" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <!-- Dark ComboBox toggle button template (dropdown arrow) -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="1" />
                <Border Grid.Column="0" Background="#FF2D2D30" Margin="1" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="#FFD4D4D4"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M0,0 L4,4 L8,0 Z" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#FF3E3E42" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#FF3E3E42" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- Dark ComboBox style with custom dropdown popup -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="BorderBrush" Value="#FF3F3F46" />
            <Setter Property="Padding" Value="6,3,23,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggleButton}"
                                          Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFD4D4D4" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="1">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFD4D4D4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="4,2" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF0078D4" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{x:Static p:Strings.Dialog_OK}" Width="80" Click="OK_Click" Margin="4"
                    Background="#FF0E639C" Foreground="White" Padding="4" />
            <Button Content="{x:Static p:Strings.Dialog_Cancel}" Width="80" IsCancel="True" Margin="4"
                    Background="#FF3E3E42" Foreground="#FFD4D4D4" Padding="4" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Board Type -->
                <TextBlock Text="{x:Static p:Strings.Settings_BoardType}" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_Board}" Style="{StaticResource SettingLabel}" />
                    <ComboBox x:Name="BoardTypeBox" Grid.Column="1"
                              SelectionChanged="BoardType_Changed">
                        <ComboBoxItem Content="Generic" />
                        <ComboBoxItem Content="MVME147" />
                    </ComboBox>
                </Grid>

                <!-- MVME147 Settings -->
                <StackPanel x:Name="Mvme147Panel" Visibility="Collapsed">
                    <TextBlock Text="{x:Static p:Strings.Settings_Mvme147Settings}" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static p:Strings.Settings_RomImage}" Style="{StaticResource SettingLabel}" />
                        <TextBox x:Name="Mvme147RomBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                        <Button Content="{x:Static p:Strings.Settings_Browse}" Grid.Column="2" Click="BrowseRom_Click"
                                Width="30" Margin="4,0,0,0"
                                Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                    </Grid>

                    <!-- Target OS -->
                    <TextBlock Text="{x:Static p:Strings.Settings_TargetOS}" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static p:Strings.Settings_OperatingSystem}" Style="{StaticResource SettingLabel}" />
                        <ComboBox x:Name="TargetOSBox" Grid.Column="1"
                                  SelectionChanged="TargetOS_Changed">
                            <ComboBoxItem Content="NetBSD" />
                            <ComboBoxItem Content="Linux" />
                        </ComboBox>
                    </Grid>
                    <!-- NetBSD-specific settings -->
                    <StackPanel x:Name="NetBsdPanel">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static p:Strings.Settings_BootPartition}" Style="{StaticResource SettingLabel}" />
                            <ComboBox x:Name="BootPartitionBox" Grid.Column="1"
                                      Width="60" HorizontalAlignment="Left">
                                <ComboBoxItem Content="a" />
                                <ComboBoxItem Content="b" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                    <!-- Linux-specific settings -->
                    <StackPanel x:Name="LinuxPanel" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static p:Strings.Settings_CommandLine}" Style="{StaticResource SettingLabel}" />
                            <TextBox x:Name="LinuxCommandLineBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                        </Grid>
                    </StackPanel>

                    <!-- SCSI Disk Settings -->
                    <TextBlock Text="{x:Static p:Strings.Settings_ScsiDisks}" Style="{StaticResource SectionHeader}" />
                    <TextBlock Text="{x:Static p:Strings.Settings_ScsiDescription}"
                               Foreground="#FF808080" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />
                    <StackPanel x:Name="ScsiDiskListPanel" />
                    <Button x:Name="AddScsiDiskBtn" Content="{x:Static p:Strings.Settings_AddDisk}" Click="AddScsiDisk_Click"
                            Margin="0,4" Padding="8,2"
                            Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock Text="{x:Static p:Strings.Settings_NewImageSizeMB}" Style="{StaticResource SettingLabel}" Width="150" />
                        <TextBox x:Name="NewScsiImageSizeBox" Width="80" Style="{StaticResource SettingTextBox}" Text="2048"
                                 ToolTip="100-2097152" />
                        <Button Content="{x:Static p:Strings.Settings_Create}" Click="CreateScsiImage_Click" Margin="8,0"
                                Background="#FF3E3E42" Foreground="#FFD4D4D4" Padding="8,2" />
                    </StackPanel>

                    <!-- SCSI CD-ROM Settings -->
                    <TextBlock Text="{x:Static p:Strings.Settings_ScsiCdRom}" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{x:Static p:Strings.Settings_IsoImage}" Style="{StaticResource SettingLabel}" />
                        <TextBox x:Name="ScsiCdromPathBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                        <Button Content="{x:Static p:Strings.Settings_Browse}" Grid.Column="2" Click="BrowseScsiCdrom_Click"
                                Width="30" Margin="4,0,0,0"
                                Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                        <TextBlock Text="{x:Static p:Strings.Settings_ScsiId}" Grid.Row="1" Style="{StaticResource SettingLabel}" />
                        <ComboBox x:Name="ScsiCdromIdBox" Grid.Row="1" Grid.Column="1"
                                  Width="60" HorizontalAlignment="Left">
                            <ComboBoxItem Content="0" />
                            <ComboBoxItem Content="1" />
                            <ComboBoxItem Content="2" />
                            <ComboBoxItem Content="3" />
                            <ComboBoxItem Content="4" />
                            <ComboBoxItem Content="5" />
                            <ComboBoxItem Content="6" />
                        </ComboBox>
                    </Grid>
                    <!-- Network Mode -->
                    <TextBlock Text="{x:Static p:Strings.Settings_Network}" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static p:Strings.Settings_NetworkMode}" Style="{StaticResource SettingLabel}" />
                        <ComboBox x:Name="NetworkModeBox" Grid.Column="1"
                                  SelectionChanged="NetworkMode_Changed">
                            <ComboBoxItem Content="Virtual (Echo Server)" />
                            <ComboBoxItem Content="NAT (Host Network)" />
                            <ComboBoxItem x:Name="TapModeItem" Content="TAP (Bridge)" />
                        </ComboBox>
                    </Grid>
                    <TextBlock Text="{x:Static p:Strings.Settings_NetworkDescription}"
                               Foreground="#FF808080" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />
                    <Grid x:Name="TapAdapterGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TAP Adapter:" Style="{StaticResource SettingLabel}" />
                        <ComboBox x:Name="TapAdapterBox" Grid.Column="1" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static p:Strings.Settings_GatewayIP}" Style="{StaticResource SettingLabel}" />
                        <TextBox x:Name="NatGatewayIpBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static p:Strings.Settings_GatewayMAC}" Style="{StaticResource SettingLabel}" />
                        <TextBox x:Name="NatGatewayMacBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                    </Grid>
                </StackPanel>

                <!-- Framebuffer -->
                <TextBlock Text="{x:Static p:Strings.Settings_Framebuffer}" Style="{StaticResource SectionHeader}" />
                <CheckBox x:Name="FramebufferEnabledBox" Content="{x:Static p:Strings.Settings_EnableFramebuffer}"
                          Foreground="#FFD4D4D4" Margin="0,4" />
                <TextBlock Text="{x:Static p:Strings.Settings_FramebufferDescription}"
                           Foreground="#FF9E9E9E" FontSize="11" TextWrapping="Wrap" Margin="20,0,0,4" />
                <Grid Margin="24,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_FbResolution}" Style="{StaticResource SettingLabel}" />
                    <ComboBox x:Name="FbResolutionBox" Grid.Column="1" Width="140" HorizontalAlignment="Left">
                        <ComboBoxItem Content="320 x 240" />
                        <ComboBoxItem Content="640 x 480" />
                        <ComboBoxItem Content="800 x 600" />
                        <ComboBoxItem Content="1024 x 768" />
                        <ComboBoxItem Content="1280 x 720" />
                        <ComboBoxItem Content="1280 x 1024" />
                        <ComboBoxItem Content="1920 x 1080" />
                    </ComboBox>
                </Grid>
                <Grid Margin="24,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_FbBpp}" Style="{StaticResource SettingLabel}" />
                    <ComboBox x:Name="FbBppBox" Grid.Column="1" Width="80" HorizontalAlignment="Left">
                        <ComboBoxItem Content="8" />
                        <ComboBoxItem Content="16" />
                        <ComboBoxItem Content="32" />
                    </ComboBox>
                </Grid>

                <!-- Memory Settings -->
                <TextBlock Text="{x:Static p:Strings.Settings_Memory}" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_MemorySizeMB}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="MemSizeBox" Grid.Column="1" Style="{StaticResource SettingTextBox}"
                             ToolTip="4-4096" />
                </Grid>
                <TextBlock Text="{x:Static p:Strings.Settings_MemoryDescription}"
                           Foreground="#FF808080" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4" />

                <!-- I/O Device Settings -->
                <TextBlock Text="{x:Static p:Strings.Settings_IoDevices}" Style="{StaticResource SectionHeader}" />

                <CheckBox x:Name="ConsoleEnabledBox" Content="{x:Static p:Strings.Settings_ConsoleEnabled}"
                          Foreground="#FFD4D4D4" Margin="0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_ConsoleBaseAddr}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="ConsoleAddrBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_ScrollbackLines}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="ConsoleScrollbackBox" Grid.Column="1" Style="{StaticResource SettingTextBox}"
                             ToolTip="0-100000" />
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_TerminalSize}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="ConsoleColumnsBox" Grid.Column="1" Style="{StaticResource SettingTextBox}"
                             ToolTip="80-320" />
                    <TextBlock Text=" x " Grid.Column="2" Style="{StaticResource SettingLabel}" HorizontalAlignment="Center" />
                    <TextBox x:Name="ConsoleRowsBox" Grid.Column="3" Style="{StaticResource SettingTextBox}"
                             ToolTip="24-80" />
                </Grid>

                <CheckBox x:Name="HddEnabledBox" Content="{x:Static p:Strings.Settings_HddEnabled}"
                          Foreground="#FFD4D4D4" Margin="0,8,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_HddBaseAddr}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="HddAddrBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>

                <!-- HDD Image Settings -->
                <TextBlock Text="{x:Static p:Strings.Settings_HddImage}" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_ImageFile}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="HddPathBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                    <Button Content="{x:Static p:Strings.Settings_Browse}" Grid.Column="2" Click="BrowseHdd_Click"
                            Width="30" Margin="4,0,0,0"
                            Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="{x:Static p:Strings.Settings_NewImageSizeMB}" Style="{StaticResource SettingLabel}" Width="150" />
                    <TextBox x:Name="NewImageSizeBox" Width="80" Style="{StaticResource SettingTextBox}" Text="2048"
                             ToolTip="100-2097152" />
                    <Button Content="{x:Static p:Strings.Settings_Create}" Click="CreateImage_Click" Margin="8,0"
                            Background="#FF3E3E42" Foreground="#FFD4D4D4" Padding="8,2" />
                </StackPanel>

                <!-- Performance -->
                <TextBlock Text="{x:Static p:Strings.Settings_Performance}" Style="{StaticResource SectionHeader}" />
                <CheckBox x:Name="JitEnabledBox" Content="{x:Static p:Strings.Settings_EnableJit}"
                          Foreground="#FFD4D4D4" Margin="0,4" />
                <TextBlock Text="{x:Static p:Strings.Settings_JitDescription}"
                           Foreground="#FF9E9E9E" FontSize="11" TextWrapping="Wrap" Margin="20,0,0,4" />
                <Grid Margin="24,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" /><ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_MinBlockLength}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="JitMinBlockLengthBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>
                <Grid Margin="24,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" /><ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_CompileThreshold}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="JitCompileThresholdBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>

                <!-- Display Settings -->
                <TextBlock Text="{x:Static p:Strings.Settings_Display}" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{x:Static p:Strings.Settings_FontFamily}" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="FontFamilyBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                    <TextBlock Text="{x:Static p:Strings.Settings_FontSize}" Grid.Row="1" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="FontSizeBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
