<Window x:Class="Em68030.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emulator Settings" Height="600" Width="540"
        Background="#FF1E1E1E" Foreground="#FFD4D4D4"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SettingTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="BorderBrush" Value="#FF3F3F46" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF569CD6" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <!-- Dark ComboBox toggle button template (dropdown arrow) -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="1" />
                <Border Grid.Column="0" Background="#FF2D2D30" Margin="1" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="#FFD4D4D4"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M0,0 L4,4 L8,0 Z" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#FF3E3E42" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#FF3E3E42" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- Dark ComboBox style with custom dropdown popup -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="BorderBrush" Value="#FF3F3F46" />
            <Setter Property="Padding" Value="6,3,23,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggleButton}"
                                          Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFD4D4D4" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="1">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFD4D4D4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="4,2" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF0078D4" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="80" Click="OK_Click" Margin="4"
                    Background="#FF0E639C" Foreground="White" Padding="4" />
            <Button Content="Cancel" Width="80" IsCancel="True" Margin="4"
                    Background="#FF3E3E42" Foreground="#FFD4D4D4" Padding="4" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Board Type -->
                <TextBlock Text="Board Type" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Board:" Style="{StaticResource SettingLabel}" />
                    <ComboBox x:Name="BoardTypeBox" Grid.Column="1"
                              SelectionChanged="BoardType_Changed">
                        <ComboBoxItem Content="Generic" />
                        <ComboBoxItem Content="MVME147" />
                    </ComboBox>
                </Grid>

                <!-- MVME147 Settings -->
                <StackPanel x:Name="Mvme147Panel" Visibility="Collapsed">
                    <TextBlock Text="MVME147 Settings" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ROM Image:" Style="{StaticResource SettingLabel}" />
                        <TextBox x:Name="Mvme147RomBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                        <Button Content="..." Grid.Column="2" Click="BrowseRom_Click"
                                Width="30" Margin="4,0,0,0"
                                Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                    </Grid>

                    <!-- SCSI Disk Settings -->
                    <TextBlock Text="SCSI Disks" Style="{StaticResource SectionHeader}" />
                    <StackPanel x:Name="ScsiDiskListPanel" />
                    <Button x:Name="AddScsiDiskBtn" Content="+ Add Disk" Click="AddScsiDisk_Click"
                            Margin="0,4" Padding="8,2"
                            Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock Text="New Image Size (MB):" Style="{StaticResource SettingLabel}" Width="150" />
                        <TextBox x:Name="NewScsiImageSizeBox" Width="60" Style="{StaticResource SettingTextBox}" Text="100" />
                        <Button Content="Create" Click="CreateScsiImage_Click" Margin="8,0"
                                Background="#FF3E3E42" Foreground="#FFD4D4D4" Padding="8,2" />
                    </StackPanel>

                    <!-- SCSI CD-ROM Settings -->
                    <TextBlock Text="SCSI CD-ROM" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Text="ISO Image:" Style="{StaticResource SettingLabel}" />
                        <TextBox x:Name="ScsiCdromPathBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                        <Button Content="..." Grid.Column="2" Click="BrowseScsiCdrom_Click"
                                Width="30" Margin="4,0,0,0"
                                Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                        <TextBlock Text="SCSI ID:" Grid.Row="1" Style="{StaticResource SettingLabel}" />
                        <ComboBox x:Name="ScsiCdromIdBox" Grid.Row="1" Grid.Column="1"
                                  Width="60" HorizontalAlignment="Left">
                            <ComboBoxItem Content="0" />
                            <ComboBoxItem Content="1" />
                            <ComboBoxItem Content="2" />
                            <ComboBoxItem Content="3" />
                            <ComboBoxItem Content="4" />
                            <ComboBoxItem Content="5" />
                            <ComboBoxItem Content="6" />
                        </ComboBox>
                    </Grid>
                    <!-- Network Mode -->
                    <TextBlock Text="Network" Style="{StaticResource SectionHeader}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Network Mode:" Style="{StaticResource SettingLabel}" />
                        <ComboBox x:Name="NetworkModeBox" Grid.Column="1">
                            <ComboBoxItem Content="Virtual (Echo Server)" />
                            <ComboBoxItem Content="NAT (Host Network)" />
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- Memory Settings -->
                <TextBlock Text="Memory" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Memory Size (MB):" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="MemSizeBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>

                <!-- I/O Device Settings -->
                <TextBlock Text="I/O Devices" Style="{StaticResource SectionHeader}" />

                <CheckBox x:Name="ConsoleEnabledBox" Content="Console Device Enabled"
                          Foreground="#FFD4D4D4" Margin="0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Console Base Addr:" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="ConsoleAddrBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Scrollback Lines:" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="ConsoleScrollbackBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>

                <CheckBox x:Name="HddEnabledBox" Content="HDD Device Enabled"
                          Foreground="#FFD4D4D4" Margin="0,8,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="HDD Base Addr:" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="HddAddrBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>

                <!-- HDD Image Settings -->
                <TextBlock Text="HDD Image" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Image File:" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="HddPathBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                    <Button Content="..." Grid.Column="2" Click="BrowseHdd_Click"
                            Width="30" Margin="4,0,0,0"
                            Background="#FF3E3E42" Foreground="#FFD4D4D4" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="New Image Size (MB):" Style="{StaticResource SettingLabel}" Width="150" />
                    <TextBox x:Name="NewImageSizeBox" Width="60" Style="{StaticResource SettingTextBox}" Text="32" />
                    <Button Content="Create" Click="CreateImage_Click" Margin="8,0"
                            Background="#FF3E3E42" Foreground="#FFD4D4D4" Padding="8,2" />
                </StackPanel>

                <!-- Performance -->
                <TextBlock Text="Performance" Style="{StaticResource SectionHeader}" />
                <CheckBox x:Name="JitEnabledBox" Content="Enable JIT Compiler (experimental)"
                          Foreground="#FFD4D4D4" Margin="0,4" />
                <TextBlock Text="Compiles register-only basic blocks to .NET IL at runtime. Currently covers a limited set of instructions (MOVEQ, MOVE.L Dn, ADD/SUB/CMP.L, AND/OR/EOR.L, Bcc.B, BRA.B). May reduce overall speed due to per-instruction overhead exceeding the benefit of compiled blocks."
                           Foreground="#FF9E9E9E" FontSize="11" TextWrapping="Wrap" Margin="20,0,0,4" />

                <!-- Display Settings -->
                <TextBlock Text="Display" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Font Family:" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="FontFamilyBox" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                    <TextBlock Text="Font Size:" Grid.Row="1" Style="{StaticResource SettingLabel}" />
                    <TextBox x:Name="FontSizeBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingTextBox}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
