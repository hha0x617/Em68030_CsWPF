<Window x:Class="Em68030.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Em68030.ViewModels"
        Title="Em68030 - MC68030 Emulator (C#/WPF)" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E" Foreground="#FFD4D4D4">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RunCommand}" />
        <KeyBinding Key="F5" Modifiers="Shift" Command="{Binding StopCommand}" />
        <KeyBinding Key="F10" Command="{Binding StepCommand}" />
        <KeyBinding Key="F4" Command="{Binding RunToCursorCommand}" />
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <vm:InverseBoolConverter x:Key="InverseBoolConverter" />

        <!-- Override SystemColors for dark theme -->
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF2D2D30" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFF0F0F0" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF2D2D30" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#FF0078D4" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF0078D4" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#FF656565" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF3E3E42" />
        <!-- Borders and 3D edges used by menu popup/item templates -->
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF2D2D30" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FF3F3F46" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FF3F3F46" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF3F3F46" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FF2D2D30" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFF0F0F0" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ActiveBorderBrushKey}" Color="#FF3F3F46" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveBorderBrushKey}" Color="#FF3F3F46" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFF0F0F0" />

        <Style x:Key="MonoText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#FFD4D4D4" />
        </Style>
        <Style x:Key="MonoTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="BorderBrush" Value="#FF3F3F46" />
            <Setter Property="CaretBrush" Value="White" />
        </Style>
        <Style x:Key="RegisterTextBox" TargetType="TextBox" BasedOn="{StaticResource MonoTextBox}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Cursor" Value="Arrow" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsRegisterEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="IsReadOnly" Value="False" />
                    <Setter Property="Cursor" Value="IBeam" />
                    <Setter Property="BorderBrush" Value="#FF569CD6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF569CD6" />
            <Setter Property="Margin" Value="4,2" />
        </Style>
        <Style x:Key="ToolBarButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3E3E42" />
            <Setter Property="Foreground" Value="#FFD4D4D4" />
            <Setter Property="BorderBrush" Value="#FF555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Focusable="False"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF505054" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF606064" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF2D2D30" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF3F3F46" />
                                <Setter Property="Foreground" Value="#FF656565" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ============================================================ -->
        <!-- Dark MenuItem: TopLevelHeader (e.g. "File", "Run") -->
        <!-- ============================================================ -->
        <ControlTemplate x:Key="DarkTopLevelHeaderTemplate" TargetType="MenuItem">
            <Grid>
                <Border x:Name="Bd" Background="Transparent" Padding="8,4">
                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                      VerticalAlignment="Center" />
                </Border>
                <Popup x:Name="PART_Popup" Placement="Bottom"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                    <Border Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="1"
                            Padding="0,4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#FF3E3E42" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#FF3E3E42" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- ============================================================ -->
        <!-- Dark MenuItem: SubmenuItem (leaf items in dropdown) -->
        <!-- ============================================================ -->
        <ControlTemplate x:Key="DarkSubmenuItemTemplate" TargetType="MenuItem">
            <Border x:Name="Bd" Background="Transparent" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                      VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}"
                               Foreground="#FF808080" Margin="20,0,0,0"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#FF0078D4" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#FF656565" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- ============================================================ -->
        <!-- Dark MenuItem: SubmenuHeader (submenu item with arrow) -->
        <!-- ============================================================ -->
        <ControlTemplate x:Key="DarkSubmenuHeaderTemplate" TargetType="MenuItem">
            <Border x:Name="Bd" Background="Transparent" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                      VerticalAlignment="Center" />
                    <Path Grid.Column="1" Fill="{TemplateBinding Foreground}"
                          Data="M0,0 L4,4 L0,8 Z" VerticalAlignment="Center" Margin="8,0,0,0" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#FF0078D4" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <!-- ============================================================ -->
        <!-- Dark MenuItem implicit style: switch template by Role -->
        <!-- ============================================================ -->
        <Style TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="#FFF0F0F0" />
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template" Value="{StaticResource DarkSubmenuItemTemplate}" />
            <Style.Triggers>
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter Property="Template" Value="{StaticResource DarkTopLevelHeaderTemplate}" />
                </Trigger>
                <Trigger Property="Role" Value="TopLevelItem">
                    <Setter Property="Template" Value="{StaticResource DarkSubmenuItemTemplate}" />
                </Trigger>
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter Property="Template" Value="{StaticResource DarkSubmenuHeaderTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Dark theme Separator style inside menus (must use SeparatorStyleKey) -->
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Margin="0,3" BorderBrush="#FF555555" BorderThickness="0,1,0,0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Fallback implicit Separator style (for non-menu separators) -->
        <Style TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Margin="0,3" BorderBrush="#FF555555" BorderThickness="0,1,0,0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Context menu item style (no icon gutter) -->
        <Style x:Key="CtxMenuItem" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="#FFF0F0F0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,5">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF0078D4" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF656565" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Context menu separator style -->
        <Style x:Key="CtxSeparator" TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Margin="4,3" BorderBrush="#FF555555" BorderThickness="0,1,0,0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark theme ContextMenu -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="Foreground" Value="#FFF0F0F0" />
            <Setter Property="BorderBrush" Value="#FF3F3F46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0,4" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="#FF2D2D30" Foreground="#FFF0F0F0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Binary..." Click="OpenBinary_Click" />
                <MenuItem Header="Open _S-Record..." Click="OpenSRecord_Click" />
                <MenuItem Header="Open _ELF..." Click="OpenElf_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Run">
                <MenuItem Header="_Run (F5)" Command="{Binding RunCommand}" />
                <MenuItem Header="_Stop (Shift+F5)" Command="{Binding StopCommand}" />
                <MenuItem Header="S_tep (F10)" Command="{Binding StepCommand}" />
                <MenuItem Header="Run to _Cursor (F4)" Click="RunToCursor_Click" />
                <Separator />
                <MenuItem Header="Set _PC to Cursor" Click="SetPCToCursor_Click" />
                <MenuItem Header="Re_set" Command="{Binding ResetCommand}" />
                <MenuItem Header="_Full Reset" Command="{Binding FullResetCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Console Window" Click="ShowConsole_Click" />
                <MenuItem Header="_Breakpoints Window" Click="ShowBreakpoints_Click" />
                <MenuItem Header="Toggle _LST View" Click="ToggleLst_Click" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Emulator Settings..." Click="Settings_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top" Background="#FF2D2D30">
            <ToolBar Background="#FF2D2D30" Band="0" BandIndex="0">
                <Button Content="Run (F5)" Command="{Binding RunCommand}" Style="{StaticResource ToolBarButton}" />
                <Button Content="Stop" Command="{Binding StopCommand}" Style="{StaticResource ToolBarButton}" />
                <Button Content="Step (F10)" Command="{Binding StepCommand}" Style="{StaticResource ToolBarButton}" />
                <Button Content="Reset" Command="{Binding ResetCommand}" Style="{StaticResource ToolBarButton}" />
                <Button Content="Full Reset" Command="{Binding FullResetCommand}" Style="{StaticResource ToolBarButton}" />
                <Button Content="Trace" Command="{Binding ToggleTraceCommand}" Style="{StaticResource ToolBarButton}" />
                <Separator />
                <TextBlock Text="{Binding LoadedFileName, StringFormat='File: {0}'}" VerticalAlignment="Center"
                           Style="{StaticResource MonoText}" Margin="8,0" />
                <TextBlock VerticalAlignment="Center" Style="{StaticResource MonoText}" Margin="8,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Cycles: {0}">
                            <Binding Path="CycleCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="{Binding EstimatedMHz}" Foreground="LightGreen" VerticalAlignment="Center"
                           Style="{StaticResource MonoText}" Margin="8,0" />
                <TextBlock Text="{Binding StopReason}" Foreground="Orange" VerticalAlignment="Center"
                           Style="{StaticResource MonoText}" Margin="8,0" />
            </ToolBar>
        </ToolBarTray>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FF007ACC">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="White" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding NetworkModeText}" Foreground="White" Margin="16,0,0,0" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="Yellow" FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTracing}" Value="True">
                                    <Setter Property="Text" Value="[TRACE ON]" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <!-- Upper pane: Disassembly + Registers -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <!-- Disassembly View -->
                <Border Grid.Column="0" BorderBrush="#FF3F3F46" BorderThickness="1" Margin="2">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#FF2D2D30">
                            <TextBlock Text="Disassembly" Style="{StaticResource HeaderText}" />
                            <TextBlock Text="Address:" Style="{StaticResource MonoText}" VerticalAlignment="Center" Margin="16,0,4,0" />
                            <TextBox x:Name="DisasmAddrBox" Width="80" Style="{StaticResource MonoTextBox}"
                                     VerticalAlignment="Center" KeyDown="DisasmAddrBox_KeyDown" />
                            <Button Content="Go" Click="DisasmGo_Click" Style="{StaticResource ToolBarButton}" Margin="4,2" />
                            <Button x:Name="BtnFollowPC" Content="Follow PC" Click="DisasmFollowPC_Click" Style="{StaticResource ToolBarButton}" Margin="4,2"
                                    IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
                            <Separator Margin="4,2" />
                            <TextBlock Text="Size:" Style="{StaticResource MonoText}" VerticalAlignment="Center" Margin="4,0,2,0" />
                            <TextBox x:Name="DisasmSizeBox" Width="50" Style="{StaticResource MonoTextBox}"
                                     VerticalAlignment="Center" Text="400" />
                            <Button x:Name="BtnManualUpdate" Content="Manual Update" Click="ManualUpdate_Click"
                                    Style="{StaticResource ToolBarButton}" Margin="4,2" />
                            <Button Content="LST" Click="ToggleLst_Click" Style="{StaticResource ToolBarButton}"
                                    Margin="8,2" Visibility="{Binding HasLstFile, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <ListBox x:Name="DisasmList" ItemsSource="{Binding DisassemblyLines}"
                                 Background="#FF1E1E1E" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="13"
                                 SelectionMode="Extended"
                                 MouseDoubleClick="DisasmList_DoubleClick"
                                 KeyDown="DisasmList_KeyDown"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="コピー" Click="DisasmCopy_Click" InputGestureText="Ctrl+C" Style="{StaticResource CtxMenuItem}" />
                                    <Separator Style="{StaticResource CtxSeparator}" />
                                    <MenuItem Header="ここまで実行" Click="ContextRunToCursor_Click" Style="{StaticResource CtxMenuItem}" />
                                    <MenuItem Header="このアドレスをPCに設定" Click="ContextSetPC_Click" Style="{StaticResource CtxMenuItem}" />
                                    <Separator Style="{StaticResource CtxSeparator}" />
                                    <MenuItem Header="キャンセル" Style="{StaticResource CtxMenuItem}" />
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Breakpoint indicator (red=enabled, gray=disabled) -->
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Margin="2,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDisabledBreakpoint}" Value="True">
                                                            <Setter Property="Fill" Value="Gray" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding HasBreakpoint}" Value="True" />
                                                                <Condition Binding="{Binding HasDisabledBreakpoint}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Fill" Value="Red" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Grid.Column="1" Text="{Binding Text}" Margin="4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas" />
                                                    <Setter Property="Foreground" Value="#FFD4D4D4" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDisabledBreakpoint}" Value="True">
                                                            <Setter Property="Foreground" Value="Gray" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCurrentPC}" Value="True">
                                                            <Setter Property="Background" Value="#FF264F78" />
                                                            <Setter Property="Foreground" Value="#FFFFFF00" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#FFD4D4D4" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Style.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF264F78" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFD4D4D4" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF3F3F46" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFD4D4D4" />
                                    </Style.Resources>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="#FF3F3F46" />

                <!-- Register Panel -->
                <Border Grid.Column="2" BorderBrush="#FF3F3F46" BorderThickness="1" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4">
                            <DockPanel>
                                <TextBlock Text="Registers" Style="{StaticResource HeaderText}" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                    <Button Content="Edit" Command="{Binding EditRegistersCommand}" Style="{StaticResource ToolBarButton}" Margin="2,0" Padding="6,2" FontSize="11" />
                                    <Button Content="Apply" Command="{Binding ApplyRegistersCommand}" Style="{StaticResource ToolBarButton}" Margin="2,0" Padding="6,2" FontSize="11" />
                                    <Button Content="Cancel" Command="{Binding CancelRegistersCommand}" Style="{StaticResource ToolBarButton}" Margin="2,0" Padding="6,2" FontSize="11" />
                                </StackPanel>
                            </DockPanel>

                            <!-- Data Registers -->
                            <TextBlock Text="Data Registers" Style="{StaticResource HeaderText}" Foreground="#FF4EC9B0" Margin="4,8,4,2" />
                            <UniformGrid Columns="2">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D0:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D0, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D1:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D1, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D2:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D2, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D3:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D3, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D4:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D4, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D5:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D5, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D6:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D6, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="D7:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding D7, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                            </UniformGrid>

                            <!-- Address Registers -->
                            <TextBlock Text="Address Registers" Style="{StaticResource HeaderText}" Foreground="#FF4EC9B0" Margin="4,8,4,2" />
                            <UniformGrid Columns="2">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A0:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A0, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A1:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A1, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A2:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A2, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A3:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A3, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A4:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A4, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A5:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A5, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A6:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A6, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="A7:" Width="30" Style="{StaticResource MonoText}" />
                                    <TextBox Text="{Binding A7, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                                </StackPanel>
                            </UniformGrid>

                            <!-- Special Registers -->
                            <TextBlock Text="Special Registers" Style="{StaticResource HeaderText}" Foreground="#FF4EC9B0" Margin="4,8,4,2" />
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="PC: " Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding PC, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="SR: " Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding SR, StringFormat=X4}" Width="75" Style="{StaticResource RegisterTextBox}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="SSP:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding SSP, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="VBR:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding VBR, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                            </StackPanel>

                            <!-- FPU Registers -->
                            <TextBlock Text="FPU Registers" Style="{StaticResource HeaderText}" Foreground="#FF4EC9B0" Margin="4,8,4,2" />
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP0:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP0, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP1:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP1, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP2:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP2, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP3:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP3, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP4:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP4, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP5:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP5, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP6:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP6, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="FP7:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FP7, StringFormat=G}" Width="110" Style="{StaticResource RegisterTextBox}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="CR: " Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FPCR, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="SR: " Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FPSR, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="IAR:" Width="35" Style="{StaticResource MonoText}" />
                                <TextBox Text="{Binding FPIAR, StringFormat=X8}" Width="75" Style="{StaticResource RegisterTextBox}" />
                            </StackPanel>

                            <!-- Flags -->
                            <TextBlock Text="Flags" Style="{StaticResource HeaderText}" Foreground="#FF4EC9B0" Margin="4,8,4,2" />
                            <WrapPanel Margin="2">
                                <CheckBox Content="X" IsChecked="{Binding FlagX}" Foreground="#FFD4D4D4" Margin="4,2" />
                                <CheckBox Content="N" IsChecked="{Binding FlagN}" Foreground="#FFD4D4D4" Margin="4,2" />
                                <CheckBox Content="Z" IsChecked="{Binding FlagZ}" Foreground="#FFD4D4D4" Margin="4,2" />
                                <CheckBox Content="V" IsChecked="{Binding FlagV}" Foreground="#FFD4D4D4" Margin="4,2" />
                                <CheckBox Content="C" IsChecked="{Binding FlagC}" Foreground="#FFD4D4D4" Margin="4,2" />
                                <CheckBox Content="S" IsChecked="{Binding FlagS}" Foreground="#FFD4D4D4" Margin="4,2" />
                                <CheckBox Content="T" IsChecked="{Binding FlagT}" Foreground="#FFD4D4D4" Margin="4,2" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="#FF3F3F46" />

            <!-- Lower pane: Memory Dump -->
            <Border Grid.Row="2" BorderBrush="#FF3F3F46" BorderThickness="1" Margin="2">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#FF2D2D30">
                        <TextBlock Text="Memory Dump" Style="{StaticResource HeaderText}" />
                        <TextBlock Text="Address:" Style="{StaticResource MonoText}" VerticalAlignment="Center" Margin="16,0,4,0" />
                        <TextBox x:Name="MemAddrBox" Width="80" Style="{StaticResource MonoTextBox}"
                                 VerticalAlignment="Center" KeyDown="MemAddrBox_KeyDown" />
                        <Button Content="Go" Click="MemGo_Click" Style="{StaticResource ToolBarButton}" Margin="4,2" />
                        <Separator Margin="8,2" />
                        <Button Content="Edit" Command="{Binding EditMemoryCommand}" Style="{StaticResource ToolBarButton}" Margin="4,2" />
                        <Button Content="Apply" Command="{Binding ApplyMemoryCommand}" Style="{StaticResource ToolBarButton}" Margin="4,2" />
                        <Button Content="Cancel" Command="{Binding CancelMemoryCommand}" Style="{StaticResource ToolBarButton}" Margin="4,2" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                    Background="#FF1E1E1E">
                        <ItemsControl x:Name="MemoryDumpList" ItemsSource="{Binding MemoryDumpRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,1">
                                        <!-- Address -->
                                        <TextBlock Text="{Binding AddressText}" Width="68"
                                                   FontFamily="Consolas" FontSize="13"
                                                   Foreground="#FF569CD6" VerticalAlignment="Center" />
                                        <TextBlock Text=": " FontFamily="Consolas" FontSize="13"
                                                   Foreground="#FF808080" VerticalAlignment="Center" />
                                        <!-- Individual byte cells -->
                                        <ItemsControl ItemsSource="{Binding Cells}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="22" FontFamily="Consolas" FontSize="13"
                                                             MaxLength="2" CharacterCasing="Upper"
                                                             Margin="1,0" Padding="1,1"
                                                             BorderThickness="1" CaretBrush="White"
                                                             TextAlignment="Center" VerticalAlignment="Center"
                                                             GotFocus="MemCell_GotFocus"
                                                             PreviewKeyDown="MemCell_PreviewKeyDown"
                                                             TextChanged="MemCell_TextChanged">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Background" Value="#FF1E1E1E" />
                                                                <Setter Property="Foreground" Value="#FFD4D4D4" />
                                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                                <Setter Property="IsReadOnly" Value="True" />
                                                                <Setter Property="Cursor" Value="Arrow" />
                                                                <Setter Property="Focusable" Value="False" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsMemoryEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="IsReadOnly" Value="False" />
                                                                        <Setter Property="Cursor" Value="IBeam" />
                                                                        <Setter Property="Focusable" Value="True" />
                                                                        <Setter Property="BorderBrush" Value="#FF3F3F46" />
                                                                        <Setter Property="Background" Value="#FF2D2D30" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                                        <Setter Property="Foreground" Value="#FFFFFF00" />
                                                                        <Setter Property="Background" Value="#FF3A3A20" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- ASCII -->
                                        <TextBlock Text="  " FontFamily="Consolas" FontSize="13"
                                                   Foreground="#FF808080" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding AsciiText}" Width="130"
                                                   FontFamily="Consolas" FontSize="13"
                                                   Foreground="#FF9CDCFE" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
